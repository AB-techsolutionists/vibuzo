{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "vibuzo",
  "permission": {
    "bash": {
      "*": "allow",
      "**/*.env": "deny",
      "**/*.env.*": "deny",
      "**/*.key": "deny",
      "**/*.pem": "deny",
      "**/*.secret*": "deny",
      "node_modules/**": "deny"
    },
    "edit": {
      "*": "allow",
      "**/*.env": "deny",
      "**/*.env.*": "deny",
      "**/*.key": "deny",
      "**/*.pem": "deny",
      "**/*.secret*": "deny"
    },
    "write": {
      "*": "allow",
      "**/*.env": "deny",
      "**/*.env.*": "deny",
      "**/*.key": "deny",
      "**/*.pem": "deny",
      "**/*.secret*": "deny"
    },
    "task": {
      "*": "allow"
    }
  }
}
